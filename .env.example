# ─────────────────────────────────────────────────────────────
# Shared infrastructure credentials and host-side port mappings.
# Copy to .env and fill in real values.
#
# Read by BOTH:
#   - compose.yaml (docker compose auto-loads the nearest .env)
#   - backend/src/config.py (via compose injecting env into the
#     server-py container)
#
# Do NOT commit the real .env. Do NOT restate these keys in
# backend/.env — that file is for backend-only settings.
# ─────────────────────────────────────────────────────────────

# ── Postgres (dev) ──────────────────────────────────────────
POSTGRES_DB=openforum
POSTGRES_USER=openforumuser
POSTGRES_PASSWORD=

# ── Redis (dev) ─────────────────────────────────────────────
REDIS_PASSWORD=

# ── Host-side port exposure ────────────────────────────────
# Override if you have local port collisions. Container-side
# ports are fixed at 5432 / 6379 / 8000 / 5173 in compose.yaml.
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=5173
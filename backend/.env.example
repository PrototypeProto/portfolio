# ─────────────────────────────────────────────────────────────
# Backend-only environment.
# Copy to backend/.env and fill in real values.
#
# Read by src/config.py after ../.env, with keys in this file
# taking precedence on collision.
#
# Do NOT restate POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB
# or REDIS_PASSWORD here — those live in ../.env as the shared
# source of truth between compose.yaml and the backend.
# ─────────────────────────────────────────────────────────────

# ── Database connection (backend-side only) ────────────────
# Host is the compose service name, not localhost, because the
# backend container reaches Postgres over the docker network.
POSTGRES_HOST=pgsql-db
POSTGRES_PORT=5432

# ── Redis connection (backend-side only) ───────────────────
REDIS_HOST=redis-db
REDIS_PORT=6379

# ── JWT ─────────────────────────────────────────────────────
# At least 32 random bytes. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256

# ── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Storage paths (relative to backend WORKDIR /backend) ───
MEDIA_DIR=shared_media
TEMPFS_DIR=tempfs_storage
LOGS_DIR=logs

# ── Environment flag ────────────────────────────────────────
# development | production
# Drives cookie secure flag, log verbosity, SQLAlchemy echo.
ENVIRONMENT=development

# ── Logging (optional) ─────────────────────────────────────
# Blank → DEBUG in development, INFO in production.
# Valid: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=
